{
  "name": "files-fixer",
  "version": "1.0.0",
  "private": true,
  "description": "Highlight and remediate file differences between two data roots in a compromised environment.",
  "type": "commonjs",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm --prefix client run dev\"",
    "build:client": "npm --prefix client run build",
    "setup": "npm install && npm --prefix client install",
    "gen-csv": "node scripts/gen-csv.js",
    "gen-sample": "node scripts/gen-sample.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "csv-parse": "^5.5.6",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
