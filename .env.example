# Copy to .env for local (non-Docker) dev. Values below point at the bundled
# sample data so `npm run dev` works out of the box on any OS.
PORT=3000
LEFT_ROOT=./sample/left
RIGHT_ROOT=./sample/right
EVIDENCE_ROOT=./sample/evidence
LEFT_CSV=./sample/evidence/left.csv
RIGHT_CSV=./sample/evidence/right.csv
CSV_PATH_PREFIX=/mnt/data
